ZXASCII
AUTO -1
PROG juros.bas
3 REM Calculo dos juros, sendo que precisa de arrays para isso
6 REM Versao 0.1: 05/04/2026: feito a partir de ZX81, adaptando cabecalho e ^
95 REM variaveis globais e atribuicao de valores
100 LET QUANTIDADE = 3
110 LET COMPOSTO = 1
120 LET PERIODO = 30.0
130 DIM A(QUANTIDADE)
140 DIM E(QUANTIDADE)
200 FOR I = 1 TO QUANTIDADE
210 LET A(I) = PERIODO * I
220 LET E(I) = 1
230 NEXT I
295 REM testa os retornos das funcoes
300 GOSUB 500
310 PRINT "Peso total = "; PESOTOTAL
320 LET JUROS = 3.0
330 GOSUB 1000
340 PRINT "Acrescimo = "; ACRESCIMO
350 LET PRECISAO = 15
360 LET MAXITERACOES = 100
370 LET MAXJUROS = 50.0
380 LET ACRESCIMOPARAM = ACRESCIMO
390 GOSUB 1500
400 PRINT "Juros = "; JUROS
450 GOTO 2000
495 REM calcula a somatoria dos pesos
500 LET PESOTOTAL = 0.0
510 FOR I = 1 TO QUANTIDADE
520 LET PESOTOTAL = PESOTOTAL + E(I)
530 NEXT I
540 RETURN
995 REM calcula o acrescimo a partir dos juros e parcelas
1000 LET ACRESCIMO = 0.0
1010 IF JUROS <= 0.0 THEN RETURN
1020 IF QUANTIDADE < 1 THEN RETURN
1030 IF PERIODO <= 0.0 THEN RETURN
1040 GOSUB 500
1050 IF PESOTOTAL <= 0.0 THEN RETURN
1060 LET ACUMULADOR = 0.0
1070 FOR I = 1 TO QUANTIDADE
1080 IF COMPOSTO = 0 THEN GOTO 1200
1100 LET ACUMULADOR = ACUMULADOR + E(I) / (1.0 + JUROS / 100.0) ^ (A(I) / PERIODO)
1110 GOTO 1300
1200 LET ACUMULADOR = ACUMULADOR = E(I) / (1.0 + JUROS / 100.0 * A(I) / PERIODO)
1300 NEXT I
1310 IF ACUMULADOR <= 0.0 THEN RETURN
1320 LET ACRESCIMO = (PESOTOTAL / ACUMULADOR - 1.0) * 100.0
1330 RETURN
1495 REM calcula os juros a partir do acrescimo e parcelas
1500 LET JUROS = 0.0
1510 IF MAXITERACOES < 1 THEN RETURN
1520 IF QUANTIDADE < 1 THEN RETURN
1530 IF PRECISAO < 1 THEN RETURN
1540 IF PERIODO <= 0.0 THEN RETURN
1550 IF ACRESCIMOPARAM <= 0.0 THEN RETURN
1560 IF MAXJUROS <= 0.0 THEN RETURN
1570 GOSUB 500
1580 IF PESOTOTAL <= 0.0 THEN RETURN
1590 LET MINJUROS = 0.0
1600 LET JUROS = MAXJUROS / 2
1610 LET MINDIFERENCA = 0.1 ^ PRECISAO
1620 FOR T = 1 TO MAXITERACOES
1630 IF (MAXJUROS - MINJUROS) < MINDIFERENCA THEN RETURN
1640 GOSUB 1000
1650 IF ACRESCIMO < ACRESCIMOPARAM THEN LET MINJUROS = JUROS
1660 IF ACRESCIMO > ACRESCIMOPARAM THEN LET MAXJUROS = JUROS
1670 LET JUROS = (MINJUROS + MAXJUROS) / 2
1680 NEXT T
1690 RETURN
